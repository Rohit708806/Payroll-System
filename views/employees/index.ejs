<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
  <h4 class="mb-0">Employees</h4>
  <% if (user && ['super_admin','hr'].includes(user.role)) { %>
  <a href="/employees/create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Add Employee</a>
  <% } %>
</div>

<div class="card mb-3">
  <div class="card-body">
    <form method="GET" class="row g-2">
      <div class="col-md-4">
        <input type="text" name="search" class="form-control" placeholder="Search..." value="<%= filters.search || '' %>">
      </div>
      <div class="col-md-3">
        <select name="department" class="form-select">
          <option value="">All Departments</option>
          <% departments.forEach(function(d) { %>
          <option value="<%= d._id %>" <%= filters.department == d._id ? 'selected' : '' %>><%= d.name %></option>
          <% }); %>
        </select>
      </div>
      <div class="col-md-2">
        <select name="status" class="form-select">
          <option value="">All Status</option>
          <option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Active</option>
          <option value="inactive" <%= filters.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
        </select>
      </div>
      <div class="col-md-3">
        <button type="submit" class="btn btn-outline-primary">Filter</button>
        <a href="/employees" class="btn btn-outline-secondary">Reset</a>
      </div>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <table class="table table-hover data-table">
      <thead>
        <tr>
          <th>Employee</th>
          <th>ID</th>
          <th>Department</th>
          <th>Designation</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% employees.forEach(function(emp) { %>
        <tr>
          <td>
            <div class="d-flex align-items-center gap-2">
              <img src="<%= emp.profilePhoto %>" class="avatar" alt="">
              <div>
                <div class="fw-semibold"><%= emp.firstName %> <%= emp.lastName %></div>
                <small class="text-muted"><%= emp.email %></small>
              </div>
            </div>
          </td>
          <td><%= emp.employeeId %></td>
          <td><%= emp.department ? emp.department.name : '-' %></td>
          <td><%= emp.designation %></td>
          <td><span class="badge bg-<%= emp.status === 'active' ? 'success' : 'secondary' %> badge-status"><%= emp.status %></span></td>
          <td>
            <a href="/employees/<%= emp._id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a>
            <% if (user && ['super_admin','hr'].includes(user.role)) { %>
            <a href="/employees/<%= emp._id %>/edit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
            <% } %>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <% if (pagination.pages > 1) { %>
    <nav>
      <ul class="pagination justify-content-center mb-0">
        <% for (let i = 1; i <= pagination.pages; i++) { %>
        <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
          <a class="page-link" href="?page=<%= i %>&<%= new URLSearchParams(filters).toString() %>"><%= i %></a>
        </li>
        <% } %>
      </ul>
    </nav>
    <% } %>
  </div>
</div>
<script>$(document).ready(function() { $('.data-table').DataTable({ pageLength: 10, order: [] }); });</script>
