<div class="profile-header mb-4">
  <div class="d-flex align-items-center gap-4">
    <img src="<%= employee.profilePhoto %>" class="avatar-lg border border-3 border-white" alt="">
    <div>
      <h3 class="mb-1"><%= employee.firstName %> <%= employee.lastName %></h3>
      <p class="mb-0 opacity-75"><%= employee.designation %> · <%= employee.employeeId %></p>
      <span class="badge bg-light text-dark mt-2"><%= employee.status %></span>
    </div>
  </div>
</div>
<div class="row g-3">
  <div class="col-md-6">
    <div class="card"><div class="card-header">Personal Info</div>
      <div class="card-body">
        <p><strong>Email:</strong> <%= employee.email %></p>
        <p><strong>Phone:</strong> <%= employee.phone || '-' %></p>
        <p><strong>Department:</strong> <%= employee.department ? employee.department.name : '-' %></p>
        <p><strong>Joined:</strong> <%= new Date(employee.joiningDate).toLocaleDateString() %></p>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card"><div class="card-header">Bank Details</div>
      <div class="card-body">
        <% if (employee.bankDetails && employee.bankDetails.bankName) { %>
        <p><strong>Bank:</strong> <%= employee.bankDetails.bankName %></p>
        <p><strong>Account:</strong> <%= employee.bankDetails.accountNumber %></p>
        <p><strong>IFSC:</strong> <%= employee.bankDetails.ifscCode %></p>
        <% } else { %><p class="text-muted">Not provided</p><% } %>
      </div>
    </div>
  </div>
  <% if (leaveBalance) { %>
  <div class="col-12">
    <div class="card"><div class="card-header">Leave Balance (<%= leaveBalance.year %>)</div>
      <div class="card-body">
        <div class="row text-center">
          <% ['annual','sick','casual'].forEach(function(type) { %>
          <div class="col-md-4">
            <h5><%= (leaveBalance.balances[type] || 0) - (leaveBalance.used[type] || 0) %></h5>
            <small class="text-muted text-capitalize"><%= type %> remaining</small>
          </div>
          <% }); %>
        </div>
      </div>
    </div>
  </div>
  <% } %>
</div>
<div class="mt-3">
  <a href="/employees" class="btn btn-outline-secondary">Back</a>
  <% if (user && ['super_admin','hr'].includes(user.role)) { %>
  <a href="/employees/<%= employee._id %>/edit" class="btn btn-primary">Edit</a>
  <% } %>
</div>
