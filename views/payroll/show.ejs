<div class="mb-4"><h4>Payroll — <%= monthName %> <%= payroll.year %></h4></div>
<div class="row g-3">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header bg-success text-white">Earnings</div>
      <div class="card-body">
        <% Object.entries(payroll.earnings).forEach(function([k,v]) { if(v) { %>
        <div class="d-flex justify-content-between py-1"><span class="text-capitalize"><%= k %></span><span>$<%= v.toLocaleString() %></span></div>
        <% }}); %>
        <hr><div class="d-flex justify-content-between fw-bold"><span>Gross</span><span>$<%= payroll.grossSalary.toLocaleString() %></span></div>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card">
      <div class="card-header bg-danger text-white">Deductions</div>
      <div class="card-body">
        <% Object.entries(payroll.deductions).forEach(function([k,v]) { if(v) { %>
        <div class="d-flex justify-content-between py-1"><span class="text-uppercase"><%= k %></span><span>$<%= v.toLocaleString() %></span></div>
        <% }}); %>
        <hr><div class="d-flex justify-content-between fw-bold"><span>Total Deductions</span><span>$<%= payroll.totalDeductions.toLocaleString() %></span></div>
      </div>
    </div>
  </div>
  <div class="col-12">
    <div class="card bg-primary text-white">
      <div class="card-body d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Net Salary</h4>
        <h3 class="mb-0">$<%= payroll.netSalary.toLocaleString() %></h3>
      </div>
    </div>
  </div>
</div>
<div class="mt-3">
  <a href="/payroll?month=<%= payroll.month %>&year=<%= payroll.year %>" class="btn btn-outline-secondary">Back</a>
  <a href="/payroll/<%= payroll._id %>/slip" class="btn btn-primary"><i class="bi bi-download"></i> Download Slip</a>
</div>
