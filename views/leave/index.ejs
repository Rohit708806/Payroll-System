<div class="d-flex justify-content-between mb-4">
  <h4>Leave Management</h4>
  <div>
    <a href="/leave/balance" class="btn btn-outline-primary btn-sm">Leave Balance</a>
    <a href="/leave/apply" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> Apply Leave</a>
  </div>
</div>
<div class="card">
  <div class="card-body table-responsive">
    <table class="table table-hover data-table">
      <thead><tr><th>Employee</th><th>Type</th><th>From</th><th>To</th><th>Days</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody>
        <% leaves.forEach(function(l) { %>
        <tr>
          <td><%= l.employee ? l.employee.firstName + ' ' + l.employee.lastName : '-' %></td>
          <td><span class="badge bg-info text-capitalize"><%= l.leaveType %></span></td>
          <td><%= new Date(l.startDate).toLocaleDateString() %></td>
          <td><%= new Date(l.endDate).toLocaleDateString() %></td>
          <td><%= l.totalDays %></td>
          <td><span class="badge bg-<%= l.status === 'approved' ? 'success' : l.status === 'rejected' ? 'danger' : 'warning' %>"><%= l.status %></span></td>
          <td>
            <% if (l.status === 'pending' && user && ['super_admin','hr','manager'].includes(user.role)) { %>
            <form action="/leave/<%= l._id %>/action" method="POST" class="d-inline">
              <%- include('../partials/csrf') %>
              <input type="hidden" name="action" value="approve">
              <button type="submit" class="btn btn-sm btn-success">Approve</button>
            </form>
            <form action="/leave/<%= l._id %>/action" method="POST" class="d-inline">
              <%- include('../partials/csrf') %>
              <input type="hidden" name="action" value="reject">
              <button type="submit" class="btn btn-sm btn-danger">Reject</button>
            </form>
            <% } else { %>—<% } %>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
<script>$(document).ready(function() { $('.data-table').DataTable(); });</script>
