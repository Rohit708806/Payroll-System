<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1">Welcome back!</h4>
    <p class="text-muted mb-0">Here's what's happening with your organization today.</p>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-sm-6 col-xl-3">
    <div class="card stat-card primary h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="stat-icon"><i class="bi bi-people"></i></div>
        <div>
          <div class="text-muted small">Total Employees</div>
          <h3 class="mb-0"><%= stats.employeeCount || 0 %></h3>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card stat-card success h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="stat-icon"><i class="bi bi-diagram-3"></i></div>
        <div>
          <div class="text-muted small">Departments</div>
          <h3 class="mb-0"><%= stats.departmentCount || 0 %></h3>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card stat-card warning h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="stat-icon"><i class="bi bi-cash-stack"></i></div>
        <div>
          <div class="text-muted small">Monthly Payroll</div>
          <h3 class="mb-0">$<%= (stats.payrollExpenses || 0).toLocaleString() %></h3>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card stat-card info h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="stat-icon"><i class="bi bi-clock"></i></div>
        <div>
          <div class="text-muted small">Present Today</div>
          <h3 class="mb-0"><%= stats.presentToday || 0 %></h3>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-lg-8">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between">
        <span>Monthly Salary Expenses</span>
        <span class="badge bg-primary"><%= new Date().getFullYear() %></span>
      </div>
      <div class="card-body" style="height: 300px;">
        <canvas id="salaryChart"
          data-labels='<%= JSON.stringify(chartLabels) %>'
          data-values='<%= JSON.stringify(chartData) %>'></canvas>
      </div>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="card h-100">
      <div class="card-header">Leave Overview</div>
      <div class="card-body" style="height: 300px;">
        <% 
          const leaveLabels = (stats.leaveStats || []).map(s => s._id);
          const leaveValues = (stats.leaveStats || []).map(s => s.count);
        %>
        <canvas id="leaveChart"
          data-labels='<%= JSON.stringify(leaveLabels) %>'
          data-values='<%= JSON.stringify(leaveValues) %>'></canvas>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header">Quick Stats</div>
      <div class="card-body">
        <div class="d-flex justify-content-between py-2 border-bottom">
          <span class="text-muted">Pending Leaves</span>
          <span class="badge bg-warning text-dark"><%= stats.pendingLeaves || 0 %></span>
        </div>
        <% (stats.attendanceSummary || []).forEach(function(item) { %>
        <div class="d-flex justify-content-between py-2 border-bottom">
          <span class="text-muted text-capitalize"><%= item._id %> (month)</span>
          <strong><%= item.count %></strong>
        </div>
        <% }); %>
      </div>
    </div>
  </div>
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header">Recent Activity</div>
      <div class="card-body p-0">
        <% if (stats.recentActivities && stats.recentActivities.length) { %>
          <% stats.recentActivities.forEach(function(act) { %>
          <div class="activity-item px-3">
            <div class="d-flex justify-content-between">
              <span><strong class="text-capitalize"><%= act.action %></strong> — <%= act.module %></span>
              <small class="text-muted"><%= new Date(act.createdAt).toLocaleString() %></small>
            </div>
            <small class="text-muted"><%= act.user ? act.user.email : 'System' %></small>
          </div>
          <% }); %>
        <% } else { %>
          <p class="text-muted p-3 mb-0">No recent activity</p>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script src="/js/dashboard.js"></script>
